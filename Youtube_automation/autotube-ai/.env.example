# =============================================================================
# AutoTube AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://autotube:autotube_secret@localhost:5432/autotube
DATABASE_URL_SYNC=postgresql://autotube:autotube_secret@localhost:5432/autotube
POSTGRES_USER=autotube
POSTGRES_PASSWORD=autotube_secret
POSTGRES_DB=autotube

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI APIs ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
STABILITY_API_KEY=sk-xxxxx
ELEVENLABS_API_KEY=xxxxx

# --- Stock Media ---
PEXELS_API_KEY=xxxxx
PIXABAY_API_KEY=xxxxx

# --- YouTube ---
YOUTUBE_CLIENT_ID=xxxxx
YOUTUBE_CLIENT_SECRET=xxxxx
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# --- App Config ---
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
MEDIA_DIR=/app/media
MAX_CONCURRENT_PIPELINES=3
DEFAULT_VIDEO_RESOLUTION=1080p
DEFAULT_CAPTION_STYLE=hormozi
LOG_LEVEL=INFO

# --- Optional: OpenAI (for Whisper captions) ---
# OPENAI_API_KEY=sk-xxxxx
