# Environment Configuration
# Copy this file to .env and fill in your values

# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# OpenAI Configuration (required for LLM features)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096

# Alternative: Anthropic Configuration
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# PostgreSQL (optional - configure if you want to connect to PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb

# MySQL (optional - configure if you want to connect to MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DB=mydb

# SQL Server (optional - configure if you want to connect to SQL Server)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=YourPassword123
MSSQL_DB=mydb

# MongoDB (optional - configure if you want to connect to MongoDB)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mydb

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# Query Configuration
MAX_QUERY_TIMEOUT=300
MAX_RESULT_ROWS=10000
ENABLE_QUERY_CACHING=True

# AI Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=True
ENABLE_AGENTIC_MODE=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
